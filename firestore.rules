rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - authenticated usage tracking
    match /users/{userId} {
      // Can read own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Can create own document with any initial data
      allow create: if request.auth != null && request.auth.uid == userId;

      // Can update own document, but cannot change plan or subscriptionType
      // (these are only changed by Cloud Functions webhook which uses admin SDK)
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.plan == resource.data.plan
                    && request.resource.data.subscriptionType == resource.data.subscriptionType;

      // Cannot delete
      allow delete: if false;
    }

    // Anonymous usage - fingerprint-based tracking
    match /anonymous_usage/{visitorId} {
      // Anyone can read/write their own fingerprint document
      // The visitorId is the fingerprint hash - hard to guess
      allow read, write: if true;
    }
  }
}
